 rules_version = '2';

  service cloud.firestore {
    match /databases/{database}/documents {

      // Helper function: Check if user is authenticated
      function isAuthenticated() {
        return request.auth != null;
      }

      // Helper function: Check if user owns the resource by path
      function isOwner(userId) {
        return isAuthenticated() && request.auth.uid == userId;
      }

      // User Profiles: Users can only read/write their own profile
      match /users/{userId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Meals: Flat collection with userId field
      match /meals/{mealId} {
        allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }

      // Grocery Lists: Flat collection with userId field
      match /groceries/{groceryId} {
        allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }

      // AI Cache: Allow authenticated users to read and write
      // (Changed from write: false to allow client-side caching)
      match /aiCache/{cacheId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false; // Prevent modification of existing cache entries
      }
    }
  }